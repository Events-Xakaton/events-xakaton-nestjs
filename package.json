{
  "name": "events-xakaton-nestjs",
  "version": "1.0.0",
  "description": "Tribe Events — бэкенд для Telegram Mini App",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch | pino-pretty -c -C",
    "typecheck": "tsc --noEmit --skipLibCheck -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=src/prisma/schema.prisma",
    "seed": "ts-node src/prisma/seed.ts",
    "docs": "compodoc -p tsconfig.json",
    "docs:serve": "compodoc -p tsconfig.json -s -r 8080"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@prisma/client": "^6.19.2",
    "@telegram-apps/init-data-node": "^2.0.10",
    "@types/speakeasy": "^2.0.10",
    "axios": "^1.13.6",
    "axios-retry": "^4.5.0",
    "bullmq": "^5.71.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "nestjs-pino": "^4.6.1",
    "nestjs-telegraf": "^2.9.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "telegraf": "^4.16.3",
    "ts-loader": "^9.5.4",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
