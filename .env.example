NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tribe_events
REDIS_URL=redis://localhost:6379
DLQ_NAME=dead-letter

JWT_SECRET=change_me
TELEGRAM_BOT_TOKEN=change_me

REDDY_BOT_BASE_URL=https://your-reddy-bot-domain
REDDY_BOT_TOKEN=change_me

LOG_LEVEL=debug

# OpenTelemetry (опционально; включать только в stage/prod или при локальном коллекторе)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=tribe-events-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_LOG_LEVEL=info
